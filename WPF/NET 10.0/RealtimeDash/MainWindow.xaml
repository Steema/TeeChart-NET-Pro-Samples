<Window x:Class="RealTimeDashClickEvent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealTimeDashClickEvent"
        xmlns:teechart="clr-namespace:Steema.TeeChart.WPF;assembly=TeeChart.WPF"
        mc:Ignorable="d"
        Title="TeeChart WPF Realtime Charting" Height="800" Width="1300" WindowState="Maximized">
    <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="3*" />
      <ColumnDefinition Width="3*" />
      <ColumnDefinition Width="1*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="1*" />
      <RowDefinition Height="1*" />
      <RowDefinition Height="1*" />
      <RowDefinition Height="1*" />
      <RowDefinition Height="1*" />
    </Grid.RowDefinitions>
    <teechart:TChart Name="tChart7" Grid.RowSpan="2"></teechart:TChart>
    <teechart:TChart Name="tChart5" Grid.Column="1" Grid.RowSpan="2"></teechart:TChart>
    <Button Name="StartStop" Grid.Column="1" Width="70" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top">Start Stop</Button>
    <teechart:TChart Name="tChart2" Grid.Column="2" Grid.Row="0"></teechart:TChart>
    <teechart:TChart Name="tChart3" Grid.Column="2" Grid.Row="1"></teechart:TChart>
    <teechart:TChart Name="tChart8" Grid.Column="0" Grid.Row="2" Grid.RowSpan="3"></teechart:TChart>
    <teechart:TChart Name="tChart6" Grid.Column="1" Grid.Row="2" Grid.RowSpan="3"></teechart:TChart>
    <teechart:TChart Name="tChart4" Grid.Column="2" Grid.Row="2"></teechart:TChart>
    <teechart:TChart Name="tChart9" Grid.Column="2" Grid.Row="3"></teechart:TChart>
    <teechart:TChart Name="tChart1" Grid.Column="2" Grid.Row="4"></teechart:TChart>
  </Grid>
</Window>
